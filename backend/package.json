{
  "name": "notes-backend",
  "version": "1.0.0",
  "description": "Express backend for Notes app",
  "main": "server.js",
  "scripts": {
    "start": "ts-node server.ts",
    "dev": "NODE_ENV=dev nodemon --exec ts-node server.ts",
    "test": "jest",
    "build": "tsc"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "mongoose": "^8.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "axios": "^1.6.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"]
  }
